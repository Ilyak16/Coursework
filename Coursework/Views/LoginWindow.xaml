<Window x:Class="Coursework.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Coursework"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="250">
            <TextBlock Text="Вход в систему"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2D6033"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30" />

            <TextBlock Text="Логин"
                   FontSize="14"
                   Foreground="#2D6033"
                   Margin="0,0,0,5" />

            <TextBox x:Name="txtuserName"
                 Height="35"
                 Padding="10,8"
                 FontSize="14"
                 BorderBrush="#2D6033"
                 BorderThickness="1"
                 Background="White"
                 Margin="0,0,0,15" />

            <TextBlock Text="Пароль"
                   FontSize="14"
                   Foreground="#2D6033"
                   Margin="0,0,0,5" />

            <PasswordBox x:Name="txtpassword"
                     Height="35"
                     Padding="10,8"
                     FontSize="14"
                     BorderBrush="#2D6033"
                     BorderThickness="1"
                     Background="White"
                     Margin="0,0,0,25" />

            <Button x:Name="btnLogin"
                Content="ВОЙТИ"
                Height="40"
                Background="#2D6033"
                Foreground="White"
                FontSize="16"
                FontWeight="Bold"
                BorderThickness="0"
                Cursor="Hand"
                Margin="0,0,0,10"
                Click="btnLogin_Click" />

            <Button x:Name="btnGuest"
                Content="ВОЙТИ КАК ГОСТЬ"
                Height="40"
                Background="#4A7A4F"
                Foreground="White"
                FontSize="14"
                FontWeight="Bold"
                BorderThickness="0"
                Cursor="Hand"
                Click="Button_Click" />
        </StackPanel>
    </Grid>
</Window>
