<Window x:Class="Coursework.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Coursework"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
            <TextBox x:Name="tbSearch" Width="200" Margin="5"/>
            <Button x:Name="btnAdd" Content="Добавить" Click="Add_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Click="Delete_Click"/>
            <Button Content="Выход" Click="Logout_Click"/>
        </StackPanel>

        <TextBlock x:Name="tbUser" HorizontalAlignment="Right"/>

        <DataGrid x:Name="dgProducts"/>
    </DockPanel>
</Window>
