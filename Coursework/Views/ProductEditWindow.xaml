<Window x:Class="Coursework.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5">

        <Border Background="White"
                Margin="20"
                Padding="20"
                CornerRadius="10">

            <ScrollViewer>
                <StackPanel>

                    <TextBlock Text="Товар"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#2D6033"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Название -->
                    <TextBlock Text="Название"/>
                    <TextBox x:Name="tbName" Margin="0,5,0,10"/>

                    <!-- Цена -->
                    <TextBlock Text="Цена"/>
                    <TextBox x:Name="tbPrice" Margin="0,5,0,10"/>

                    <!-- Количество -->
                    <TextBlock Text="Количество на складе"/>
                    <TextBox x:Name="tbStock" Margin="0,5,0,10"/>

                    <!-- Категория -->
                    <TextBlock Text="Категория"/>
                    <ComboBox x:Name="cbCategory" Margin="0,5,0,10"/>

                    <!-- Производитель -->
                    <TextBlock Text="Производитель"/>
                    <ComboBox x:Name="cbManufacturer" Margin="0,5,0,10"/>

                    <!-- Скидка -->
                    <TextBlock Text="Скидка (%)"/>
                    <TextBox x:Name="tbDiscount" Margin="0,5,0,10"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Сохранить"
                                Width="120"
                                Height="35"
                                Margin="5"
                                Background="#2D6033"
                                Foreground="White"
                                Click="Save_Click"/>

                        <Button Content="Отмена"
                                Width="120"
                                Height="35"
                                Margin="5"
                                Click="Cancel_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </Border>
    </Grid>
</Window>